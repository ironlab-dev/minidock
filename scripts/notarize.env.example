# =============================================================================
# App Store Connect API Key — Notarization Credentials Template
# =============================================================================
#
# Copy this file to PROJECT_ROOT/.notarize.env and fill in your values.
# .notarize.env is git-ignored and must NEVER be committed.
#
# How to get these values:
#   1. Go to https://appstoreconnect.apple.com/access/integrations/api
#   2. Click "+" to create a new API Key (role: Developer is sufficient)
#   3. Copy the Issuer ID shown at the top of the page
#   4. Copy the Key ID from the key row
#   5. Download the .p8 file (only downloadable once — store it safely)
#
# =============================================================================

# 10-character Key ID (shown next to the key name)
ASC_KEY_ID=XXXXXXXXXX

# UUID-format Issuer ID (shown at top of the API Keys page)
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Absolute path to the downloaded .p8 private key file
ASC_KEY_PATH=/Users/YOUR_USERNAME/private/AuthKey_XXXXXXXXXX.p8
