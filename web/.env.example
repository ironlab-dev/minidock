# MiniDock Environment Configuration

# Backend API URL (auto-configured by dev.sh based on directory name)
# Default: http://localhost:24000
# If directory name contains a number (e.g., minidock2), ports are adjusted accordingly
NEXT_PUBLIC_API_URL=http://localhost:24000

